<!DOCTYPE html>
<html>
<head>
  <title>Habitat Restoration | Patricia Bishop</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>

    :root {
      --olive: #A1814D;
      --paper: #D9C8AB;
      --clay: #9E5C3E;
      --ink: #1f241c;
      --cream: #fbf7ef;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--cream);
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
    }

    .top {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 10;
      padding: 28px 36px;
    }

    .top a {
      color: rgba(31,36,28,.75);
      text-decoration: none;
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: .18em;
      font-size: 11px;
    }

    .hero {
      height: 45vh;
      background-image: url("marsh.jpg");
      background-size: cover;
      background-position: center;
      position: relative;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(20,22,18,.28);
    }

    .hero-overlay {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-text {
      width: 100%;
      max-width: 760px;
      margin: 0 auto;
      padding: 0 90px;
      color: white;
    }

    .hero-text h1 {
      font-size: clamp(42px, 6vw, 72px);
      line-height: .95;
      margin: 0;
      font-weight: normal;
    }

    .hero-subtitle {
      margin-top: 18px;
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: .16em;
      font-size: 12px;
      opacity: .9;
    }

    .content {
      max-width: 760px;
      margin: 0 auto;
      padding: 30px 90px 70px;
    }

    p {
      line-height: 1.9;
      font-size: 19px;
    }

    .content a {
      color: var(--clay);
      text-decoration: none;
    }

    .content a:hover {
      text-decoration: underline;
    }

    .page-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 60px;
      padding-top: 20px;
    }

    .page-nav a {
      color: var(--clay);
      text-decoration: none;
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: .14em;
      font-size: 11px;
    }

    .page-nav a:hover {
      text-decoration: underline;
    }

    @media (max-width: 850px) {

      .content {
        padding: 60px 34px 70px;
      }

      .hero {
        height: 40vh;
      }

      .hero-overlay {
        justify-content: flex-start;
      }

      .hero-text {
        width: 100%;
        padding: 0 34px;
        margin: 0;
      }

      .hero-text h1 {
        font-size: clamp(34px, 9vw, 52px);
      }

      .page-nav {
        flex-direction: column;
        gap: 18px;
        align-items: flex-start;
      }

    }

  </style>
</head>

<body>

<div class="top">
  <a href="work.html">← Work</a>
</div>

<div class="hero">
  <div class="hero-overlay">
    <div class="hero-text">
      <h1>Habitat Restoration & Conservation</h1>

      <div class="hero-subtitle">
        Rachel Carson National Wildlife Refuge
      </div>
    </div>
  </div>
</div>

<div class="content">

  <p>
    Content coming soon.
  </p>

  <div class="page-nav">
    <a href="alosine.html">← Juvenile Alosine Ecology</a>

    <a href="work.html">Work →</a>
  </div>

</div>

</body>
</html>
